---
source: crates/cockpit-editor/tests/golden_vim.rs
expression: "snapshot(\"normal_motions\", &chars(\"hjklwbe0^$G\"))"
---
case: normal_motions
start_mode: Normal
steps:
  - key: Char('h')
    actions:
      - Move(Left)
  - key: Char('j')
    actions:
      - Move(Line(Down))
  - key: Char('k')
    actions:
      - Move(Line(Up))
  - key: Char('l')
    actions:
      - Move(Right)
  - key: Char('w')
    actions:
      - Move(WordForward)
  - key: Char('b')
    actions:
      - Move(WordBackward)
  - key: Char('e')
    actions:
      - Move(WordEnd)
  - key: Char('0')
    actions:
      - Move(LineStart)
  - key: Char('^')
    actions:
      - Move(FirstNonWhitespace)
  - key: Char('$')
    actions:
      - Move(LineEnd)
  - key: Char('G')
    actions:
      - Move(FileEnd)
final_mode: Normal
